#!/bin/sh
# Validates Conventional Commits format: type(optional-scope): subject
MSG=$(cat "$1")
if ! echo "$MSG" | grep -qE "^(feat|fix|chore|docs|test|refactor|perf|build|ci|revert)(\(.+\))?: .+"; then
  echo ""
  echo "ERROR: Invalid commit message format."
  echo "Required: type(optional-scope): subject"
  echo "Examples:"
  echo "  feat: add user registration"
  echo "  fix(auth): handle expired token"
  echo "  chore: update dependencies"
  echo ""
  exit 1
fi
